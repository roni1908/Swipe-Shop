<!-- SwipeShop Full Page Template for Shopify -->
<!-- Save as templates/page.swipeshop.liquid -->

{% layout 'theme' %}

<div class="swipeshop-page">
  <div class="page-width">
    <!-- Page Header -->
    <div class="swipeshop-hero">
      <div class="hero-content">
        <h1 class="hero-title">{{ page.title | default: "SwipeShop Experience" }}</h1>
        <p class="hero-subtitle">{{ page.content | strip_html | truncate: 200 | default: "Discover products in a whole new way. Swipe through our collection and find your favorites!" }}</p>
      </div>
    </div>

    <!-- SwipeShop App Container -->
    <div class="swipeshop-app-container">
      <div id="swipeshop-full-app"></div>
      
      <!-- Loading State -->
      <div id="swipeshop-loading" class="swipeshop-loading">
        <div class="loading-spinner"></div>
        <p>Loading SwipeShop...</p>
      </div>
    </div>

    <!-- Analytics Dashboard for Admin -->
    {% if customer and customer.tags contains 'admin' %}
    <div class="swipeshop-admin-panel">
      <h2>Admin Analytics</h2>
      <div id="swipeshop-analytics"></div>
    </div>
    {% endif %}
  </div>
</div>

<!-- SwipeShop Integration Script -->
<script>
  // Shopify store data
  window.ShopifyStoreData = {
    shop: '{{ shop.permanent_domain }}',
    currency: '{{ shop.currency }}',
    customer: {% if customer %}{{ customer | json }}{% else %}null{% endif %},
    isAdmin: {% if customer and customer.tags contains 'admin' %}true{% else %}false{% endif %},
    products: [
      {% paginate collections.all.products by 100 %}
        {% for product in collections.all.products %}
          {
            id: '{{ product.id }}',
            handle: '{{ product.handle }}',
            title: {{ product.title | json }},
            price: {{ product.price | money_without_currency | remove: ',' }},
            compare_at_price: {% if product.compare_at_price %}{{ product.compare_at_price | money_without_currency | remove: ',' }}{% else %}null{% endif %},
            available: {{ product.available | json }},
            images: [
              {% for image in product.images limit: 10 %}
                {{ image | img_url: '1000x1000' | json }}{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ],
            variants: [
              {% for variant in product.variants %}
                {
                  id: '{{ variant.id }}',
                  title: {{ variant.title | json }},
                  price: {{ variant.price | money_without_currency | remove: ',' }},
                  available: {{ variant.available | json }},
                  sku: {{ variant.sku | json }}
                }{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ],
            vendor: {{ product.vendor | json }},
            type: {{ product.type | json }},
            tags: {{ product.tags | json }},
            collections: [
              {% for collection in product.collections %}
                {{ collection.handle | json }}{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ]
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      {% endpaginate %}
    ]
  };

  // Load SwipeShop React App
  window.loadSwipeShop = function() {
    // Remove loading state
    document.getElementById('swipeshop-loading').style.display = 'none';
    
    // Create iframe for the React app
    const iframe = document.createElement('iframe');
    iframe.id = 'swipeshop-react-app';
    iframe.src = `https://your-swipeshop-domain.com/shopify-embed?data=${encodeURIComponent(JSON.stringify(window.ShopifyStoreData))}`;
    iframe.style.cssText = `
      width: 100%;
      height: 100vh;
      border: none;
      border-radius: 8px;
    `;
    
    document.getElementById('swipeshop-full-app').appendChild(iframe);

    // Handle messages from React app
    window.addEventListener('message', function(event) {
      if (event.origin !== 'https://your-swipeshop-domain.com') return;
      
      switch(event.data.type) {
        case 'ADD_TO_CART':
          addToShopifyCart(event.data.variantId, event.data.quantity);
          break;
        case 'VIEW_PRODUCT':
          window.location.href = `/products/${event.data.handle}`;
          break;
        case 'UPDATE_ANALYTICS':
          if (window.ShopifyStoreData.isAdmin) {
            updateAnalytics(event.data.analytics);
          }
          break;
      }
    });
  };

  // Add to Shopify cart
  async function addToShopifyCart(variantId, quantity = 1) {
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: quantity
        })
      });
      
      if (response.ok) {
        // Show success message
        showNotification('Product added to cart!', 'success');
        
        // Update cart count
        if (window.theme && window.theme.cart) {
          window.theme.cart.refresh();
        }
      } else {
        throw new Error('Failed to add to cart');
      }
    } catch (error) {
      console.error('Error adding to cart:', error);
      showNotification('Error adding product to cart', 'error');
    }
  }

  // Show notification
  function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `swipeshop-notification swipeshop-notification--${type}`;
    notification.textContent = message;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.classList.add('swipeshop-notification--show');
    }, 100);
    
    setTimeout(() => {
      notification.classList.remove('swipeshop-notification--show');
      setTimeout(() => {
        document.body.removeChild(notification);
      }, 300);
    }, 3000);
  }

  // Update analytics for admin
  function updateAnalytics(analytics) {
    const container = document.getElementById('swipeshop-analytics');
    if (container && analytics) {
      container.innerHTML = `
        <div class="analytics-grid">
          <div class="analytics-card">
            <h3>Total Swipes</h3>
            <span class="analytics-number">${analytics.totalSwipes || 0}</span>
          </div>
          <div class="analytics-card">
            <h3>Likes</h3>
            <span class="analytics-number">${analytics.likes || 0}</span>
          </div>
          <div class="analytics-card">
            <h3>Love Its</h3>
            <span class="analytics-number">${analytics.loveIts || 0}</span>
          </div>
          <div class="analytics-card">
            <h3>Conversion Rate</h3>
            <span class="analytics-number">${analytics.conversionRate || 0}%</span>
          </div>
        </div>
      `;
    }
  }

  // Initialize when page loads
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(loadSwipeShop, 1000); // Small delay for better UX
  });
</script>

<style>
  .swipeshop-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  }

  .swipeshop-hero {
    text-align: center;
    padding: 60px 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    margin-bottom: 40px;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .swipeshop-app-container {
    position: relative;
    min-height: 70vh;
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .swipeshop-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 400px;
    color: #666;
  }

  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #f0f0f0;
    border-top: 4px solid #667eea;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .swipeshop-admin-panel {
    margin-top: 40px;
    padding: 20px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 20px;
  }

  .analytics-card {
    padding: 20px;
    background: #f8f9fa;
    border-radius: 8px;
    text-align: center;
  }

  .analytics-card h3 {
    margin: 0 0 10px 0;
    color: #666;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .analytics-number {
    font-size: 2rem;
    font-weight: bold;
    color: #333;
  }

  .swipeshop-notification {
    position: fixed;
    top: 20px;
    right: 20px;
    padding: 15px 20px;
    border-radius: 8px;
    color: white;
    font-weight: 500;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 1000;
  }

  .swipeshop-notification--show {
    transform: translateX(0);
  }

  .swipeshop-notification--success {
    background: #28a745;
  }

  .swipeshop-notification--error {
    background: #dc3545;
  }

  .swipeshop-notification--info {
    background: #17a2b8;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }
    
    .hero-subtitle {
      font-size: 1rem;
    }
    
    .swipeshop-hero {
      padding: 40px 20px;
    }
  }
</style>
